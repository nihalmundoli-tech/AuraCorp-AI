# AuraCorp-AI Environment Variables Template

# 1. LLM API (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Google Sheets Integration
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Service Account JSON (Minified string)
# Create a Service Account in Google Cloud Console, download the JSON key, and minify it.
GOOGLE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# 3. Server Config
PORT=3000
